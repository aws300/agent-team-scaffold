#!/bin/bash
# cma-deploy — the platform runtime: fulfil cma.yaml against the Managed Agents API.
# Exposed on the Bash PATH while the plugin is enabled (plugin `bin/`). Thin wrapper
# over scripts/cma/deploy.py so you can run `cma-deploy session <project> <workflow>`.
# Default is DRY-RUN; pass --apply for real API calls (needs ANTHROPIC_API_KEY +
# ANTHROPIC_ENVIRONMENT_ID). See docs/平台设计文档.md §8 and docs/平台使用文档.md §7.

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -f "${CLAUDE_PLUGIN_ROOT}/scripts/cma/deploy.py" ]; then
    ROOT="${CLAUDE_PLUGIN_ROOT}"
else
    ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
fi

exec python3 "${ROOT}/scripts/cma/deploy.py" "$@"
