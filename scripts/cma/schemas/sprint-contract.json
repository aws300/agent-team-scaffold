{
  "type": "object",
  "required": ["deliverable", "status", "acceptance_criteria"],
  "additionalProperties": false,
  "properties": {
    "deliverable": { "type": "string", "maxLength": 80, "pattern": "^[A-Za-z0-9 _-]+$" },
    "status": { "enum": ["draft", "ready", "blocked"] },
    "scope": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 200 }
    },
    "out_of_scope": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 200 }
    },
    "dependencies": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 200 }
    },
    "acceptance_criteria": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["criterion", "verification"],
        "additionalProperties": false,
        "properties": {
          "criterion": { "type": "string", "maxLength": 240 },
          "verification": { "type": "string", "maxLength": 240 }
        }
      }
    }
  }
}
